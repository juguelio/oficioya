        "body": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $('POST /webhook/emergency').first().json.body.client_phone }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"⏳ El profesional no está disponible. Buscando otro...\" }\n}",
        "options": {}
      }
    },
    {
      "id": "node-check-if-matched",
