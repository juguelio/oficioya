        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "id,status" },
            { "name": "id",     "value": "=eq.{{ $('Supabase: Create Emergency Request').first().json.id }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "node-if-was-matched",
      "name": "IF: Se encontró match?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1680, 400],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-was-matched",
              "leftValue": "={{ $json.status }}",
