# NUNCA pongas valores reales acá ni en CLAUDE.md. Copiá a .env.local (no se trackea).

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PostHog — analytics de validación (conteo de clics de WhatsApp, ADR-001).
# Si quedan vacías, analytics es no-op y la app funciona igual.
VITE_POSTHOG_KEY=phc_your-project-key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# n8n webhooks (leave empty to disable)
VITE_N8N_WEBHOOK_WELCOME_EMAIL=https://your-n8n-instance.com/webhook/welcome-email
VITE_N8N_WEBHOOK_NEW_PROVIDER=https://your-n8n-instance.com/webhook/new-provider
VITE_N8N_WEBHOOK_NEW_JOB=https://your-n8n-instance.com/webhook/new-job

# Anthropic (n8n — clasificador de respuestas de outreach)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Places API (New) — n8n, ingesta automática de prospectos (workflow 06)
GOOGLE_PLACES_API_KEY=your-google-places-key

# Apify — n8n, ingesta de Instagram/Facebook (workflow 08). Token de tu cuenta Apify.
APIFY_TOKEN=apify_api_your-token

# Canal de monitoreo del digest diario (workflow 07): Slack incoming webhook,
# Telegram (via adaptador), o tu bot Hermes. Recibe POST { text }.
MONITOR_WEBHOOK_URL=https://hooks.slack.com/services/...

# MercadoPago
MP_ACCESS_TOKEN=APP_USR-your-access-token

# n8n
N8N_BASE_URL=https://your-n8n-instance.com
APP_URL=https://oficio.app

# WhatsApp Business API (360dialog or compatible)
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_API_KEY=your-360dialog-api-key

# Supabase (server-side — n8n only, never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
