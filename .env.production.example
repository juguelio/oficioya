# ──────────────────────────────────────────────────────────────────────────────
# Oficio — Production environment variables (Vercel)
#
# Copy these into Vercel → Project Settings → Environment Variables.
# All VITE_ vars are inlined at build time by Vite — they are NOT secret.
# Never add SUPABASE_SERVICE_ROLE_KEY or any server-side secret here.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — project dmzdvjfctkfxefhxjmkm
VITE_SUPABASE_URL=https://dmzdvjfctkfxefhxjmkm.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# n8n webhooks — triggered by ProviderSignup on successful registration
# Leave empty to silently skip (notifications.ts checks before calling)
VITE_N8N_WEBHOOK_WELCOME_EMAIL=https://your-n8n-instance.com/webhook/welcome-email
VITE_N8N_WEBHOOK_NEW_PROVIDER=https://your-n8n-instance.com/webhook/new-provider

# Google Maps JavaScript API — mapa de /emergencias (browser). Restringí la key por HTTP
# referrer a oficioya.app/* y *.oficioya.app/*. Habilitá "Maps JavaScript API".
VITE_GOOGLE_MAPS_API_KEY=your-maps-js-browser-key

# MercadoPago public key (no secreta). El access token va como Supabase secret, no acá.
VITE_MP_PUBLIC_KEY=APP_USR-your-public-key
